# ===================================================
# TELOS Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values.

# --- Provider Selection ---
# Options: "azure" | "azure_sk" | "azure_foundry" | optional fallback: "gemini"
TELOS_PROVIDER=azure_foundry

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure AI Foundry (AI Dev Days hero tech) ---
AZURE_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com
AZURE_FOUNDRY_API_KEY=your-foundry-api-key
AZURE_FOUNDRY_MODEL=gpt-4o

# --- Optional Google Gemini Fallback (not used in Microsoft submission build) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Orchestrator ---
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080

# --- Scheduler ---
SCHEDULER_HOST=127.0.0.1
SCHEDULER_PORT=8081

# --- Windows MCP ---
WINDOWS_MCP_HOST=127.0.0.1
WINDOWS_MCP_PORT=8083

# --- Go Capture Engine (screenshot service) ---
SCREENSHOT_ENGINE_HOST=127.0.0.1
SCREENSHOT_ENGINE_PORT=8085

# --- Rust Delta Engine (visual diff) ---
DELTA_ENGINE_HOST=127.0.0.1
DELTA_ENGINE_PORT=8084

# --- Privacy ---
TELOS_PRIVACY_MODE=strict
TELOS_ALLOW_IMAGE_EGRESS=false
TELOS_EGRESS_LOG=./logs/egress.jsonl
TELOS_EGRESS_CACHE_SIZE=1000

# --- Database / Memory ---
TELOS_DB_PATH=./telos_memory_db/telos.db
TELOS_MEMORY_BACKEND=sqlite # or "firestore"
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_COLLECTION=telos_tasks

# --- API Security ---
# Leave blank for local/dev. When set, all non-health API routes require this token.
TELOS_API_TOKEN=
# Optional internal token accepted by the orchestrator for service-to-service calls.
TELOS_INTERNAL_TOKEN=
# Optional scheduler override when the orchestrator uses a different token.
ORCHESTRATOR_API_TOKEN=

# --- Microsoft Hero Tech ---
SEMANTIC_KERNEL_ENABLED=true
AZURE_MCP_ENABLED=true

# --- Logging ---
TELOS_LOG_LEVEL=info
