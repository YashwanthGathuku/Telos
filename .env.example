# TELOS Gemini submission configuration
# Copy this file to .env and fill in the values you will use for the demo.

# Gemini submission path
TELOS_PROVIDER=gemini
GOOGLE_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
TELOS_MEMORY_BACKEND=sqlite
FIRESTORE_COLLECTION=telos_tasks

# Local service addresses
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080
SCHEDULER_HOST=127.0.0.1
SCHEDULER_PORT=8081
WINDOWS_MCP_HOST=127.0.0.1
WINDOWS_MCP_PORT=8083
DELTA_ENGINE_HOST=127.0.0.1
DELTA_ENGINE_PORT=8084
SCREENSHOT_ENGINE_HOST=127.0.0.1
SCREENSHOT_ENGINE_PORT=8085

# Privacy and egress
TELOS_PRIVACY_MODE=balanced
TELOS_ALLOW_IMAGE_EGRESS=true
TELOS_EGRESS_LOG=./logs/egress.jsonl
TELOS_EGRESS_CACHE_SIZE=1000

# Persistence
TELOS_DB_PATH=./telos_memory_db/telos.db

# Optional API protection
TELOS_API_TOKEN=
TELOS_INTERNAL_TOKEN=
ORCHESTRATOR_API_TOKEN=

# Logging
TELOS_LOG_LEVEL=info
